# App
ENV=development

# PostgreSQL
DATABASE_URL=postgresql+psycopg://postgres:your_password@localhost:5432/optimark-v1

# JWT / Auth
JWT_SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Password hashing
PBKDF2_ITERATIONS=210000

# Default admin seed (only created when there are no users)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@optimark.app
DEFAULT_ADMIN_PASSWORD=change-me
DEFAULT_ADMIN_FULL_NAME=System Admin
DEFAULT_ADMIN_SCHOOL=OptiMark Demo School

# Frontend CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
